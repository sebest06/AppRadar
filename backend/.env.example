# Puerto del servidor (default: 3000)
PORT=3000

# Clave secreta para firmar JWT — cambiá este valor en producción
JWT_SECRET=cambia_este_valor_secreto_en_produccion

# Orígenes CORS permitidos (separados por coma)
# En producción: el dominio donde está deployado el frontend
CORS_ORIGINS=http://localhost:5173,http://localhost:4173

# Cooldown entre carreras del mismo usuario en la misma ruta (minutos)
# 0 = sin cooldown (útil para tests y desarrollo)
RACE_COOLDOWN_MINUTES=60

# Ambiente — "production" activa el servidor de archivos estáticos del frontend
NODE_ENV=development
